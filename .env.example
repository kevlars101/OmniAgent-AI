ENVIRONMENT=local
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://omniagent:omnipass@localhost:5432/omniagent_db
POSTGRES_USER=omniagent
POSTGRES_PASSWORD=omnipass
POSTGRES_DB=omniagent_db

# Authentication (Backend Dummy Auth or Clerk)
AUTH_ISSUER=
AUTH_AUDIENCE=
AUTH_DEV_USER_ID=00000000-0000-0000-0000-000000000001
AUTH_DEV_EMAIL=local@omniagent.ai

# Clerk Auth (Frontend & Backend)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# RAG / Documents
UPLOAD_DIR=var/uploads
MAX_UPLOAD_MB=25

# ChromaDB
CHROMA_PATH=var/chroma
CHROMA_COLLECTION=omniagent_documents

# Embeddings / LLMs
EMBEDDING_PROVIDER=gemini
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=text-embedding-004

CHUNK_SIZE=1200
CHUNK_OVERLAP=180
